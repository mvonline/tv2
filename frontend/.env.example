# Frontend environment template — copy to frontend/.env.local and adjust.
# Vite reads .env.local automatically (gitignored, never committed).

# Where Vite dev server proxies /api requests.
# Default: http://127.0.0.1:8787  (matches uvicorn main:app default port).
# Override if your backend runs on a different host or port.
# VITE_DEV_API_PROXY=http://127.0.0.1:8787

# Full origin for /api/categories when the API lives on a different origin
# (e.g. a deployed backend while running the frontend elsewhere).
# Omit for same-origin setups (local dev or Docker).
# VITE_API_BASE=http://localhost:8787

# Optional absolute URL for channel logos (paths in JSON stay logo/…).
# If unset, dev/proxy loads GET /api/config from the API (backend LOGOS_BASE_URL).
# VITE_LOGOS_BASE_URL=https://cdn.example.com/my-prefix

# Full URL to the HLS proxy ending with /proxy/hls.
# Only required for a static/production build served WITHOUT the Vite dev/preview
# server (which has the HLS proxy built in).
# VITE_HLS_PROXY_BASE=http://localhost:8787/proxy/hls

# Base path when deploying to a GitHub project sub-path (e.g. /repo-name/).
# Leave unset for root deployments.
# VITE_BASE=/
