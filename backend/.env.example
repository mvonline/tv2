# Backend environment template — copy to backend/.env and fill in values.
# Loaded automatically by main.py via python-dotenv.

# Admin credentials for /admin UI and /api/admin endpoints.
# Leave ADMIN_PASSWORD empty to disable the admin entirely.
ADMIN_USER=admin
ADMIN_PASSWORD=changeme

# Optional HMAC secret for signing the admin_session cookie.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# ADMIN_SESSION_SECRET=

# Comma-separated CORS origins allowed to call the API.
# Use * to allow all (default), or restrict to your frontend origin.
CORS_ORIGINS=*

# Path to the SQLite categories database.
# Default: backend/data/categories.db (relative to where uvicorn is run).
# CATEGORY_DB_PATH=backend/data/categories.db

# Optional: HTTP(S) URL to download channels.json when the API starts (local uvicorn or Docker).
# Also pass via Compose `.env` if you use Docker. SKIP_CHANNELS_FETCH=1 skips this.
# CHANNELS_JSON_URL=https://example.com/path/to/channels.json
# CHANNELS_JSON_PATH=backend/data/channels.json
# SKIP_CHANNELS_FETCH=0

# Optional URL prefix for every relative channel.logo path from channels.json (SPA reads GET /api/config).
# Exposed as GET /api/config → logos_base_url for the SPA.
# LOGOS_BASE_URL=https://cdn.example.com
